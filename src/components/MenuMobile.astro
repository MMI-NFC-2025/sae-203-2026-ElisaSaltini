---

---

<nav
    id="mobile-menu"
    class="pointer-events-none fixed inset-0 z-50 translate-x-full opacity-0 transition-all duration-500 ease-out"
    aria-hidden="true"
>
    <div class="min-h-screen bg-primary px-7 pt-12 pb-10">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a
                    href="/404"
                    aria-label="Instagram"
                    class="flex h-10 w-10 items-center justify-center rounded-full bg-white"
                >
                    <img
                        src="/images/button-insta.webp"
                        alt=""
                        class="h-10 w-10 object-contain"
                    />
                </a>

                <a
                    href="/404"
                    aria-label="Facebook"
                    class="flex h-10 w-10 items-center justify-center rounded-full bg-white"
                >
                    <img
                        src="/images/button-facebook.webp"
                        alt=""
                        class="h-10 w-10 object-contain"
                    />
                </a>

                <a
                    href="/404"
                    aria-label="TikTok"
                    class="flex h-10 w-10 items-center justify-center rounded-full bg-white"
                >
                    <img
                        src="/images/button-tiktok.webp"
                        alt=""
                        class="h-10 w-10 object-contain"
                    />
                </a>
            </div>

            <div class="flex items-center gap-4">
                <a
                    href="/404"
                    aria-label="Billetterie"
                    class="flex h-10 w-10 items-center justify-center rounded-full bg-white"
                >
                    <img
                        src="/images/button-ticket.webp"
                        alt=""
                        class="h-10 w-10 object-contain"
                    />
                </a>

                <button
                    id="close-menu-button"
                    type="button"
                    aria-label="Fermer le menu"
                    class="flex h-10 w-10 items-center justify-center rounded-full bg-white text-primary"
                >
                    <span class="relative block h-5 w-5">
                        <span
                            class="absolute left-1/2 top-1/2 block h-[2px] w-5 -translate-x-1/2 -translate-y-1/2 rotate-45 bg-primary"
                        ></span>
                        <span
                            class="absolute left-1/2 top-1/2 block h-[2px] w-5 -translate-x-1/2 -translate-y-1/2 -rotate-45 bg-primary"
                        ></span>
                    </span>
                </button>
            </div>
        </div>

        <ul
            class="mt-14 flex flex-col gap-11 font-text text-[2rem] leading-none text-white"
        >
            <li class="menu-item">
                <a href="/notre-festival" class="block"> Notre Festival </a>
            </li>

            <li class="menu-item">
                <a href="/programme" class="block"> Le Programme </a>
            </li>

            <li class="menu-item">
                <a href="/artistes" class="block"> Les artistes </a>
            </li>

            <li class="menu-item">
                <a href="/scenes" class="block"> Les scènes </a>
            </li>

            <li class="menu-item">
                <a href="/contact" class="block"> Nous contacter </a>
            </li>

            <li class="menu-item">
                <a href="/faq" class="block"> FAQ </a>
            </li>
        </ul>

        <div class="menu-logo mt-16 flex justify-center">
            <img
                src="/svg/logo.svg"
                alt="Fanfa' Comtoise du 26 au 28 juin"
                class="w-full max-w-[18rem]"
            />
        </div>
    </div>
</nav>

<style>
    #mobile-menu .menu-item {
        opacity: 0;
        transform: translateX(24px);
        transition:
            opacity 0.45s ease,
            transform 0.45s ease;
    }

    #mobile-menu .menu-logo {
        opacity: 0;
        transform: translateY(20px);
        transition:
            opacity 0.45s ease,
            transform 0.45s ease;
    }

    #mobile-menu.is-active .menu-item {
        opacity: 1;
        transform: translateX(0);
    }

    #mobile-menu.is-active .menu-item:nth-child(1) {
        transition-delay: 0.18s;
    }

    #mobile-menu.is-active .menu-item:nth-child(2) {
        transition-delay: 0.26s;
    }

    #mobile-menu.is-active .menu-item:nth-child(3) {
        transition-delay: 0.34s;
    }

    #mobile-menu.is-active .menu-item:nth-child(4) {
        transition-delay: 0.42s;
    }

    #mobile-menu.is-active .menu-item:nth-child(5) {
        transition-delay: 0.5s;
    }

    #mobile-menu.is-active .menu-item:nth-child(6) {
        transition-delay: 0.58s;
    }

    #mobile-menu.is-active .menu-logo {
        opacity: 1;
        transform: translateY(0);
        transition-delay: 0.68s;
    }
</style>
