---

---

<section class="relative min-h-screen overflow-hidden bg-primary">
    <div class="absolute inset-0 z-0">
        <img
            src="/images/hero.webp"
            alt=""
            class="h-full w-full object-cover object-center"
        />
    </div>

    <div
        class="absolute inset-0 z-10 bg-[linear-gradient(to_bottom,rgba(45,156,175,0.92)_0%,rgba(45,156,175,0.68)_28%,rgba(45,156,175,0.22)_58%,rgba(45,156,175,0.78)_100%)]"
    >
    </div>

    <div
        class="absolute inset-x-0 top-0 z-20 h-[38%] bg-[radial-gradient(circle_at_top,rgba(123,206,220,0.42)_0%,rgba(123,206,220,0.18)_38%,rgba(123,206,220,0)_72%)]"
    >
    </div>

    <div
        class="absolute inset-x-0 bottom-0 z-20 h-[34%] bg-[linear-gradient(to_top,rgba(45,156,175,0.96)_0%,rgba(45,156,175,0.78)_45%,rgba(45,156,175,0)_100%)]"
    >
    </div>

    <div class="absolute inset-0 z-5 translate-y-8">
        <img
            src="/images/confettis.webp"
            alt=""
            class="h-full w-full object-cover object-center"
        />
    </div>

    <div
        class="relative z-40 mx-auto flex min-h-screen w-full max-w-5xl flex-col items-center px-6 pb-12 pt-[20rem] text-center lg:px-10 lg:pt-[15.5rem]"
    >
        <h1
            class="font-title text-[3rem] font-semibold leading-[0.95] text-white lg:max-w-3xl lg:text-[4rem]"
        >
            Au centre-ville
            <br />
            de Montbéliard
        </h1>

        <a
            href="/404"
            class="mt-10 inline-flex items-center rounded-2xl bg-white px-5 py-3 shadow-[0_6px_16px_rgba(0,0,0,0.18)] transition-transform duration-200 hover:-translate-y-0.5"
        >
            <span class="font-text text-[1.05rem] font-medium text-primary">
                Accéder à la billetterie
            </span>

            <span class="relative ml-3 block h-4 w-4">
                <span
                    class="absolute left-0 top-1/2 h-[2.5px] w-full -translate-y-1/2 rounded-full bg-primary"
                ></span>
                <span
                    class="absolute right-0 top-1/2 h-[2.5px] w-[58%] origin-right -translate-y-1/2 rotate-45 rounded-full bg-primary"
                ></span>
                <span
                    class="absolute right-0 top-1/2 h-[2.5px] w-[58%] origin-right -translate-y-1/2 -rotate-45 rounded-full bg-primary"
                ></span>
            </span>
        </a>

        <div class="mt-9 flex flex-col items-center pb-8 lg:pb-10">
            <h2
                class="font-text text-subtitle leading-[1.3] text-white lg:max-w-[30rem]"
            >
                Découvrez les
                <br />
                premières infos !
            </h2>

            <a
                href="#programme"
                aria-label="Descendre dans la page"
                class="mt-10 flex h-24 w-24 items-center justify-center"
            >
                <span class="relative block h-20 w-20">
                    <!-- chevron 1 -->
                    <span
                        class="absolute left-[18%] top-[18%] block h-[8px] w-[42%] rotate-45 rounded-full bg-accent shadow-[0_0_14px_rgba(251,255,36,0.5)]"
                    ></span>
                    <span
                        class="absolute right-[18%] top-[18%] block h-[8px] w-[42%] -rotate-45 rounded-full bg-accent shadow-[0_0_14px_rgba(251,255,36,0.5)]"
                    ></span>

                    <!-- chevron 2 -->
                    <span
                        class="absolute left-[18%] top-[46%] block h-[8px] w-[42%] rotate-45 rounded-full bg-accent shadow-[0_0_14px_rgba(251,255,36,0.5)]"
                    ></span>
                    <span
                        class="absolute right-[18%] top-[46%] block h-[8px] w-[42%] -rotate-45 rounded-full bg-accent shadow-[0_0_14px_rgba(251,255,36,0.5)]"
                    ></span>
                </span>
            </a>
        </div>
    </div>
</section>
