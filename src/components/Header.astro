---
import MenuMobile from "./MenuMobile.astro";

const currentPath = Astro.url.pathname;

const navLinks = [
    { href: "/", label: "Accueil" },
    { href: "/notre-festival", label: "Le festival" },
    { href: "/programme", label: "Programme" },
    { href: "/artistes", label: "Artistes" },
    { href: "/scenes", label: "Scènes" },
    { href: "/faq", label: "FAQ" },
    { href: "/contact", label: "Contact" },
];

function isActive(href) {
    if (href === "/") {
        return currentPath === "/";
    }

    return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header
    id="site-header"
    class="fixed left-0 top-0 z-[100] w-full bg-primary px-7 pb-6 pt-12 transition-transform duration-300 ease-in-out lg:px-10 lg:pb-5 lg:pt-8"
>
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
            <a
                href="/404"
                aria-label="Instagram"
                class="flex h-10 w-10 items-center justify-center rounded-full bg-white"
            >
                <img
                    src="/images/button-insta.webp"
                    alt=""
                    class="h-10 w-10 object-contain"
                />
            </a>

            <a
                href="/404"
                aria-label="Facebook"
                class="flex h-10 w-10 items-center justify-center rounded-full bg-white"
            >
                <img
                    src="/images/button-facebook.webp"
                    alt=""
                    class="h-10 w-10 object-contain"
                />
            </a>

            <a
                href="/404"
                aria-label="TikTok"
                class="flex h-10 w-10 items-center justify-center rounded-full bg-white"
            >
                <img
                    src="/images/button-tiktok.webp"
                    alt=""
                    class="h-10 w-10 object-contain"
                />
            </a>
        </div>

        <div class="flex items-center gap-4">
            <a
                href="/404"
                aria-label="Billetterie"
                class="flex h-10 w-10 items-center justify-center rounded-full bg-white"
            >
                <img
                    src="/images/button-ticket.webp"
                    alt=""
                    class="h-10 w-10 object-contain"
                />
            </a>

            <button
                id="menu-button"
                aria-label="Ouvrir le menu"
                class="burger-button relative flex h-10 w-10 items-center justify-center rounded-full bg-white lg:hidden"
                type="button"
            >
                <span class="burger-lines relative block h-5 w-5">
                    <span
                        class="burger-line burger-line-1 absolute left-0 top-0.5 block h-[2px] w-full bg-primary transition-all duration-300 ease-in-out"
                    ></span>
                    <span
                        class="burger-line burger-line-2 absolute left-[25%] top-1/2 block h-[2px] w-[75%] -translate-y-1/2 bg-primary transition-all duration-300 ease-in-out"
                    ></span>
                    <span
                        class="burger-line burger-line-3 absolute bottom-0.5 left-0 block h-[2px] w-full bg-primary transition-all duration-300 ease-in-out"
                    ></span>
                </span>
            </button>
        </div>
    </div>

    <div class="mt-10 flex justify-center lg:mt-6">
        <a href="/" aria-label="Retour a l'accueil">
            <img
                src="/svg/logo.svg"
                alt="Fanfa' Comtoise du 26 au 28 juin"
                class="w-full max-w-[34rem] lg:max-w-[26rem]"
            />
        </a>
    </div>

    <nav
        class="mt-8 hidden lg:block"
        aria-label="Navigation principale"
    >
        <ul
            class="flex flex-wrap items-center justify-center gap-x-4 gap-y-3 font-text text-[1.05rem] text-white"
        >
            {
                navLinks.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            class:list={[
                                "rounded-full px-4 py-1.5 transition-colors duration-200",
                                isActive(link.href)
                                    ? "bg-white text-primary"
                                    : "hover:bg-white/20",
                            ]}
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>
    </nav>

    <MenuMobile />
</header>

<style>
    .burger-button.is-active .burger-line-1 {
        top: 50%;
        transform: translateY(-50%) rotate(45deg);
    }

    .burger-button.is-active .burger-line-2 {
        opacity: 0;
    }

    .burger-button.is-active .burger-line-3 {
        top: 50%;
        bottom: auto;
        transform: translateY(-50%) rotate(-45deg);
    }

    .header-hidden {
        transform: translateY(-100%);
    }
</style>

<script>
    //@ts-nocheck

    const header = document.querySelector("#site-header");
    const menuButton = document.querySelector("#menu-button");
    const closeMenuButton = document.querySelector("#close-menu-button");
    const mobileMenu = document.querySelector("#mobile-menu");

    let lastScrollY = window.scrollY;

    function openMenu() {
        if (!mobileMenu || !menuButton) {
            return;
        }

        mobileMenu.classList.remove(
            "pointer-events-none",
            "translate-x-full",
            "opacity-0",
        );
        mobileMenu.classList.add("is-active");
        mobileMenu.setAttribute("aria-hidden", "false");

        menuButton.classList.add("is-active");
        document.body.classList.add("overflow-hidden");
    }

    function closeMenu() {
        if (!mobileMenu || !menuButton) {
            return;
        }

        mobileMenu.classList.remove("is-active");
        mobileMenu.classList.add(
            "pointer-events-none",
            "translate-x-full",
            "opacity-0",
        );
        mobileMenu.setAttribute("aria-hidden", "true");

        menuButton.classList.remove("is-active");
        document.body.classList.remove("overflow-hidden");
    }

    function handleHeaderScroll() {
        if (!header) {
            return;
        }

        const currentScrollY = window.scrollY;
        const menuOpen =
            mobileMenu && mobileMenu.classList.contains("is-active");

        if (menuOpen) {
            header.classList.remove("header-hidden");
            lastScrollY = currentScrollY;
            return;
        }

        if (currentScrollY <= 20) {
            header.classList.remove("header-hidden");
            lastScrollY = currentScrollY;
            return;
        }

        if (currentScrollY > lastScrollY) {
            header.classList.add("header-hidden");
        } else {
            header.classList.remove("header-hidden");
        }

        lastScrollY = currentScrollY;
    }

    if (menuButton) {
        menuButton.addEventListener("click", openMenu);
    }

    if (closeMenuButton) {
        closeMenuButton.addEventListener("click", closeMenu);
    }

    window.addEventListener("scroll", handleHeaderScroll);
</script>
