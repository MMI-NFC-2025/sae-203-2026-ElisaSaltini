---
const { images = [], nomArtiste = "" } = Astro.props;
---

{
    images.length > 0 && (
        <section class="bg-primary-light py-8 md:py-10">
            <div class="my-grid">
                <div class="w-full lg:col-span-10 lg:col-start-2">
                    <div class="relative" data-artist-carousel>
                        <div class="overflow-hidden rounded-xl">
                            <div
                                class="flex transition-transform duration-500 ease-out"
                                data-track
                            >
                                {images.map((image, index) => (
                                    <div class="w-full min-w-full flex-shrink-0">
                                        <img
                                            src={image}
                                            alt={`${nomArtiste} photo ${index + 1}`}
                                            class="h-72 w-full object-cover md:h-[24rem] lg:h-[30rem]"
                                        />
                                    </div>
                                ))}
                            </div>
                        </div>

                        <button
                            class="absolute left-3 top-1/2 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-primary/60 text-white backdrop-blur-sm"
                            type="button"
                            aria-label="Image précédente"
                            data-prev
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6">
                                <path fill-rule="evenodd" d="M11.72 10.28a.75.75 0 0 1 0 1.06l-1.72 1.72H15.75a.75.75 0 0 1 0 1.5H10.06l1.72 1.72a.75.75 0 1 1-1.06 1.06l-3-3a.75.75 0 0 1 0-1.06l3-3a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd"></path>
                                <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25Z" clip-rule="evenodd"></path>
                            </svg>
                        </button>

                        <button
                            class="absolute right-3 top-1/2 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-primary/60 text-white backdrop-blur-sm"
                            type="button"
                            aria-label="Image suivante"
                            data-next
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6">
                                <path fill-rule="evenodd" d="M12.28 10.28a.75.75 0 0 1 1.06 0l3 3a.75.75 0 0 1 0 1.06l-3 3a.75.75 0 1 1-1.06-1.06l1.72-1.72H8.25a.75.75 0 0 1 0-1.5h5.69l-1.72-1.72a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"></path>
                                <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25Z" clip-rule="evenodd"></path>
                            </svg>
                        </button>

                        <div class="mt-4 flex justify-center gap-2">
                            {images.map((_, i) => (
                                <button
                                    type="button"
                                    class={`h-3 w-3 rounded-full transition-colors duration-300 ${i === 0 ? "bg-accent" : "bg-primary"}`}
                                    data-dot={i}
                                    aria-label={`Voir la photo ${i + 1}`}
                                ></button>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>
    )
}

<script>
    //@ts-nocheck

    const carousels = document.querySelectorAll("[data-artist-carousel]");

    carousels.forEach((carousel) => {
        const track = carousel.querySelector("[data-track]");
        const prev = carousel.querySelector("[data-prev]");
        const next = carousel.querySelector("[data-next]");
        const dots = carousel.querySelectorAll("[data-dot]");

        if (!track || !prev || !next) {
            return;
        }

        const total = track.children.length;
        let current = 0;

        if (total <= 1) {
            prev.classList.add("hidden");
            next.classList.add("hidden");
        }

        function goTo(index) {
            current = (index + total) % total;
            track.style.transform = `translateX(-${current * 100}%)`;

            dots.forEach((dot, i) => {
                dot.classList.toggle("bg-accent", i === current);
                dot.classList.toggle("bg-primary", i !== current);
            });
        }

        prev.addEventListener("click", () => goTo(current - 1));
        next.addEventListener("click", () => goTo(current + 1));

        dots.forEach((dot, index) => {
            dot.addEventListener("click", () => goTo(index));
        });

        goTo(0);
    });
</script>
