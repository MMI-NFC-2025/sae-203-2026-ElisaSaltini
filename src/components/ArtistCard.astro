---
import FavoriteStar from "./FavoriteStar.astro";

const { artiste, imageUrl } = Astro.props;
const isFavori = artiste.Favori === true;
---

<article class="group relative overflow-hidden rounded-2xl bg-white p-2 shadow-md ring-1 ring-white/40 transition-shadow duration-300 hover:shadow-xl md:p-3">
    <a href={`/artistes/${artiste.id}`} class="block">
        <div class="relative overflow-hidden rounded-xl">
            <img
                src={imageUrl}
                alt={artiste.Nom}
                class="h-52 w-full object-cover transition-transform duration-300 group-hover:scale-[1.03] md:h-60 lg:h-64"
            />
            <div
                class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/28 via-transparent to-transparent"
            ></div>
        </div>

        <div class="px-3 py-4 text-center">
            <h3 class="font-title text-subtitle text-primary lg:text-[1.9rem]">
                {artiste.Nom}
            </h3>
        </div>
    </a>

    <FavoriteStar
        artisteId={artiste.id}
        isFavori={isFavori}
        className="absolute right-3 top-3 z-20 h-11 w-11 md:right-4 md:top-4"
    />
</article>
