---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import ArtistesHero from "../../components/ArtistesHero.astro";
import ArtistCard from "../../components/ArtistCard.astro";
import { getArtistesByDate, getImageUrl } from "../../../backend/backend.mjs";

const tousLesArtistes = await getArtistesByDate();

const artistesAvecImage = tousLesArtistes.map((artiste) => {
    let imageUrl = "/images/image1home.webp";

    if (artiste.Image_artiste) {
        imageUrl = getImageUrl(artiste, artiste.Image_artiste);
    }

    return {
        artiste,
        imageUrl,
    };
});
---

<Layout titre="Les artistes">
    <section class="relative">
        <Header />
        <ArtistesHero />
    </section>

    <section id="liste-artistes" class="bg-primary pb-16 pt-8">
        <div class="my-grid gap-y-8 lg:items-start">
            <div class="lg:col-span-3 lg:pr-6">
                <h2 class="text-center font-title text-title text-white lg:text-left">
                    La liste des artistes
                </h2>

                <p
                    class="mx-auto mt-5 max-w-md text-center font-text text-body leading-[1.7] text-white/90 lg:mx-0 lg:text-left"
                >
                    Parcourez tous les artistes programmés et accédez à leur
                    fiche complète en un clic.
                </p>
            </div>

            <div class="mt-2 grid gap-8 md:grid-cols-2 lg:col-span-9 lg:mt-0 xl:grid-cols-3">
                {
                    artistesAvecImage.map(({ artiste, imageUrl }) => (
                        <ArtistCard artiste={artiste} imageUrl={imageUrl} />
                    ))
                }
            </div>
        </div>
    </section>
</Layout>
