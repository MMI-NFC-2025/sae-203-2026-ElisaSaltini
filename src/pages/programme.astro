---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import ProgrammeHero from "../components/ProgrammeHero.astro";
---

<Layout titre="Programme">
    <section class="relative">
        <Header />
        <ProgrammeHero />
    </section>

    <section id="programme-content" class="bg-primary pb-16 pt-8">
        <div class="my-grid">
            <div class="lg:col-span-4 lg:pt-2">
                <div class="flex justify-center lg:justify-start">
                    <a
                        href="https://ton-lien-externe-ici.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 rounded-2xl bg-white px-6 py-3 font-text text-primary shadow-lg"
                    >
                        Télécharger la prog' ↗
                    </a>
                </div>
            </div>

            <div class="mt-12 lg:col-span-8 lg:mt-0">
                <div class="space-y-8">
                    <article class="rounded-3xl border border-white/20 bg-primary-light/15 px-6 py-7 text-center lg:px-8 lg:text-left">
                        <h2
                            class="text-center font-title text-[2.55rem] font-semibold leading-[0.95] text-white lg:text-left"
                        >
                            Vendredi 26 Juin 2026
                        </h2>

                        <p class="mt-8 font-text text-[1.4rem] text-accent">
                            Scène Place Saint-Martin
                        </p>

                        <p class="mt-2 font-text text-body leading-[1.5] text-white">
                            La Cédille - Ozma - Abigoba -
                            <br />
                            Minoritaire - Borruto Family
                        </p>
                    </article>

                    <article class="rounded-3xl border border-white/20 bg-primary-light/15 px-6 py-7 text-center lg:px-8 lg:text-left">
                        <h2
                            class="text-center font-title text-[2.55rem] font-semibold leading-[0.95] text-white lg:text-left"
                        >
                            Samedi 27 Juin
                            <br />
                            2026
                        </h2>

                        <p class="mt-8 font-text text-[1.4rem] text-accent">
                            Place Albert Thomas
                        </p>

                        <p class="mt-2 font-text text-body leading-[1.5] text-white">
                            Fanfare les 5 Fantastiques - Batterie
                            <br />
                            Fanfare Municipale de Mâcon - Buck
                            <br />
                            - Wiho & The Free Radical
                        </p>
                    </article>

                    <article class="rounded-3xl border border-white/20 bg-primary-light/15 px-6 py-7 text-center lg:px-8 lg:text-left">
                        <h2 class="text-center font-title text-[2.55rem] font-semibold leading-[0.95] text-white lg:text-left">
                            Dimanche 28 Juin 2026
                        </h2>

                        <p class="mt-8 font-text text-[1.4rem] text-accent">
                            Place Denfert Rochereau
                        </p>

                        <p class="mt-2 font-text text-body leading-[1.5] text-white">
                            Ibrahim Maalouf - Émile Parisien -
                            <br />
                            Médéric Collignon - Boulou Ferré -
                            <br />
                            Louis Sclavis
                        </p>
                    </article>
                </div>

                <div class="mt-12 flex justify-center lg:justify-start">
                    <a
                        href="/404"
                        class="inline-flex items-center gap-2 rounded-2xl bg-white px-6 py-3 font-text text-primary shadow-lg"
                    >
                        Accéder à la billetterie ↗
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
