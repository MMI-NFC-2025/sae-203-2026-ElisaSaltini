---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import ScenesHero from "../../components/ScenesHero.astro";
import SceneCard from "../../components/SceneCard.astro";
import { getScenesByName, getImageUrl } from "../../../backend/backend.mjs";

const toutesLesScenes = await getScenesByName();

const scenesAvecImage = toutesLesScenes.map((scene) => {
    let imageUrl = "/images/hero.webp";

    if (scene.Image_scene) {
        imageUrl = getImageUrl(scene, scene.Image_scene);
    }

    return {
        scene,
        imageUrl,
    };
});
---

<Layout titre="Les scènes">
    <section class="relative">
        <Header />
        <ScenesHero />
    </section>

    <section id="liste-scenes" class="bg-primary pb-16 pt-8">
        <div class="my-grid gap-y-8 lg:items-start">
            <div class="lg:col-span-3 lg:pr-6">
                <h2 class="text-center font-title text-title text-white lg:text-left">
                    La liste des scènes
                </h2>

                <p
                    class="mx-auto mt-5 max-w-2xl text-center font-text text-body leading-[1.7] text-white/90 lg:mx-0 lg:text-left"
                >
                    Cliquez sur une image pour l'ouvrir en grand et mieux découvrir
                    chaque lieu du festival.
                </p>
            </div>

            <div class="mt-2 grid gap-8 md:grid-cols-2 lg:col-span-9 lg:mt-0 xl:grid-cols-3">
                {
                    scenesAvecImage.map(({ scene, imageUrl }) => (
                        <SceneCard scene={scene} imageUrl={imageUrl} />
                    ))
                }
            </div>
        </div>
    </section>
</Layout>
