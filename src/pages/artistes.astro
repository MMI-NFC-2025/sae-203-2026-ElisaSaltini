---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import ArtistesHero from "../components/ArtistesHero.astro";
import ArtistCard from "../components/ArtistCard.astro";
import { getArtistesByDate, getImageUrl } from "../../backend/backend.mjs";

const jourActif = Astro.url.searchParams.get("jour") || "all";

const tousLesArtistes = await getArtistesByDate();

let artistesFiltres = tousLesArtistes;

if (jourActif !== "all") {
    artistesFiltres = tousLesArtistes.filter((artiste) =>
        artiste.Debut_representation?.startsWith(jourActif),
    );
}

const artistesAvecImage = artistesFiltres.map((artiste) => {
    let imageUrl = "/images/image1home.webp";

    if (artiste.Image_artiste) {
        imageUrl = getImageUrl(artiste, artiste.Image_artiste);
    }

    return {
        artiste,
        imageUrl,
    };
});
---

<Layout titre="Les artistes">
    <section class="relative">
        <Header />
        <ArtistesHero />
    </section>

    <section id="liste-artistes" class="bg-primary px-6 pt-8 pb-16">
        <div class="mx-auto max-w-md">
            <h2 class="font-title text-title text-center text-white">
                La liste des artistes
            </h2>

            <div class="mt-8 grid grid-cols-2 gap-4">
                <a
                    href="/artistes?jour=2026-06-26"
                    class={`flex min-h-[7rem] items-center justify-center rounded-[1.4rem] px-4 text-center font-text text-[1.1rem] font-semibold leading-[1.2] transition ${
                        jourActif === "2026-06-26"
                            ? "bg-white text-primary shadow-lg"
                            : "bg-primary-light text-white"
                    }`}
                >
                    Vendredi
                    <br />
                    26 Juin 2026
                </a>

                <a
                    href="/artistes?jour=2026-06-27"
                    class={`flex min-h-[7rem] items-center justify-center rounded-[1.4rem] px-4 text-center font-text text-[1.1rem] font-semibold leading-[1.2] transition ${
                        jourActif === "2026-06-27"
                            ? "bg-white text-primary shadow-lg"
                            : "bg-primary-light text-white"
                    }`}
                >
                    Samedi
                    <br />
                    27 Juin 2026
                </a>

                <a
                    href="/artistes?jour=2026-06-28"
                    class={`flex min-h-[7rem] items-center justify-center rounded-[1.4rem] px-4 text-center font-text text-[1.1rem] font-semibold leading-[1.2] transition ${
                        jourActif === "2026-06-28"
                            ? "bg-white text-primary shadow-lg"
                            : "bg-primary-light text-white"
                    }`}
                >
                    Dimanche
                    <br />
                    28 Juin 2026
                </a>

                <a
                    href="/artistes"
                    class={`flex min-h-[7rem] items-center justify-center rounded-[1.4rem] px-4 text-center font-text text-[1.1rem] font-semibold leading-[1.2] transition ${
                        jourActif === "all"
                            ? "bg-white text-primary shadow-lg"
                            : "bg-primary-light text-white"
                    }`}
                >
                    Afficher
                    <br />
                    tout
                </a>
            </div>

            <div class="mt-10 space-y-8">
                {
                    artistesAvecImage.map(({ artiste, imageUrl }) => (
                        <ArtistCard artiste={artiste} imageUrl={imageUrl} />
                    ))
                }
            </div>
        </div>
    </section>
</Layout>
